# Groq API
GROQ_API_KEY=your_groq_api_key_here

# Model Configuration
LLM_MODEL=llama-3.1-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Audio Processing
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Diarization (IMPORTANT: Get token from https://huggingface.co/settings/tokens)
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
HF_TOKEN=your_huggingface_token_here

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True